# 🔥 Fire Detection System Environment Configuration
# Copy to .env và điền giá trị thật
# ❌ KHÔNG commit file .env lên Git (add to .gitignore)

# ─────────── SERVER ───────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# ─────────── APP INFO ───────────
APP_NAME=Fire Detection LLM Agent
APP_VERSION=1.0.0

# ─────────── SECURITY (REQUIRED) ───────────
# ⚠️ Thay bằng giá trị ngẫu nhiên trong production
AGENT_API_KEY=your-super-secret-api-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# ─────────── LLM - OpenAI ───────────
# Nếu bỏ trống, sẽ dùng mock LLM
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4-vision
LLM_MAX_TOKENS=200

# ─────────── FIRE DETECTION - YOLO ───────────
YOLO_MODEL_NAME=yolov8m.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_NMS_THRESHOLD=0.45

# ─────────── FIREBASE (Optional - cho sensor data) ───────────
FIREBASE_DB_URL=https://your-project.firebaseio.com
FIREBASE_KEY_PATH=/app/firebase-key.json

# ─────────── RATE LIMITING ───────────
RATE_LIMIT_PER_MINUTE=30

# ─────────── COST GUARD - LLM BUDGET ───────────
MONTHLY_BUDGET_USD=50.0
ALERT_BUDGET_PERCENT=0.8

# ─────────── REDIS (for distributed rate limiting) ───────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# ─────────── CORS ───────────
ALLOWED_ORIGINS=*
